# Copia este archivo a .env (o configura estas variables en Railway)

# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=pon_aqui_tu_token

# Tu chat_id personal (obtenido de @userinfobot) — el bot SOLO te obedece a ti
AUTHORIZED_CHAT_ID=123456789

# API key de OpenAI (console.openai.com)
OPENAI_API_KEY=sk-proj-...

# ID de tu Google Sheet (la parte larga entre /d/ y /edit de la URL)
GOOGLE_SHEET_ID=1SC-VwpYVAjbI7r-wYQ1VzBKyEgUQeM5ODjp5GmtzgU4

# Nombre de la pestaña del TRACKER dentro del Sheet
TRACKER_SHEET_NAME=TRACKER

# Contenido COMPLETO del archivo JSON de credenciales de Google Cloud
# (todo el JSON en una sola línea, entre comillas simples)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Zona horaria (por defecto Madrid)
TIMEZONE=Europe/Madrid
